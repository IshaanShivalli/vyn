# Validation.vyn - Input and type validation helpers
import String

isNil = function(val) perform
    return val == NIL
endFunc

isPositive = function(n) perform
    return n > 0
endFunc

isNegative = function(n) perform
    return n < 0
endFunc

isZero = function(n) perform
    return n == 0
endFunc

inRange = function(n, low, high) perform
    return n >= low and n <= high
endFunc

isNonEmpty = function(str) perform
    return length(trim(str)) > 0
endFunc

hasMinLength = function(str, min) perform
    return length(str) >= min
endFunc

hasMaxLength = function(str, max) perform
    return length(str) <= max
endFunc