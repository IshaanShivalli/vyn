# Assertions, proof blocks, and timed blocks.
assert 1 + 1 == 2, "math still works"

proof "basic arithmetic" do
  assert 2 * 3 == 6, "multiplication"
  assert 10 - 4 == 6, "subtraction"
endProof

proofReport

timed "small loop" do
  total = 0
  forLoop { i = 1; i <= 100; i: i + 1 } do
    total = total + i
  endLoop
endTimed

timedReport
timedClear
